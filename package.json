{
  "name": "obs-pms-w-tunnel",
  "version": "2.0.4",
  "description": "OBS Presentation Management System with Tunnel",
  "main": "index.js",
  "type": "module",
  "author": "muozez",
  "license": "MIT",
  "scripts": {
    "start": "node index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "bundle": "esbuild index.js --bundle --platform=node --format=cjs --outfile=dist/bundle.js --external:fsevents --log-override:empty-import-meta=silent",
    "package": "npm run bundle && pkg . --targets node18-win-x64 --output obs-pms-w-tunnel.exe"
  },
  "bin": "dist/bundle.js",
  "pkg": {
    "assets": [
      "index.html",
      "settings.html"
    ],
    "outputPath": "."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-log": "^5.4.3",
    "express": "^5.2.1",
    "obs-websocket-js": "^5.0.8",
    "socket.io": "^4.8.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1"
  }
}
