{
  "name": "obs-remote",
  "version": "1.0.0",
  "description": "OBS Presentation Remote Control",
  "author": "Antigravity",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "bundle": "esbuild index.js --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:electron",
    "package": "npm run bundle && copy index.html dist\\index.html /Y && copy settings.html dist\\settings.html /Y && pkg . --targets node18-win-x64 --output obs-remote.exe"
  },
  "bin": "dist/server.cjs",
  "pkg": {
    "assets": [
      "dist/index.html",
      "dist/settings.html"
    ],
    "outputPath": "."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-log": "^5.4.3",
    "express": "^5.2.1",
    "obs-websocket-js": "^5.0.8",
    "socket.io": "^4.8.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.2",
    "pkg": "^5.8.1"
  }
}
